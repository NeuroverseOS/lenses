# Lenses App — Environment Variables

# Your MentraOS app API key (from console.mentra.glass)
# This authenticates your app server with MentraOS.
MENTRA_APP_API_KEY=your_mentra_app_api_key_here

# Port to run the app server on (default: 3000)
PORT=3000

# NOTE: User AI API keys are NOT stored here.
# Users enter their own key in the app's Settings screen
# on their phone. Their key, their cost, their data.
# We never see it. We never store it. We never touch it.
