{
  "name": "@neuroverse/lenses",
  "version": "1.0.0",
  "private": true,
  "description": "Lenses — Pick who you want in your corner. A governed AI companion for MentraOS smart glasses.",
  "type": "module",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "build": "tsc && cp src/worlds/*.nv-world.md dist/worlds/",
    "postinstall": "node -e \"const f='node_modules/@neuroverseos/governance/package.json';const p=JSON.parse(require('fs').readFileSync(f));delete p.exports;require('fs').writeFileSync(f,JSON.stringify(p,null,2))\"",
    "demo": "tsx src/demo.ts",
    "demo:live": "tsx src/demo-live.ts",
    "validate": "tsx src/validate.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mentra/sdk": "3.0.0-hono.8",
    "@neuroverseos/governance": "^0.4.0",
    "@anthropic-ai/sdk": "^0.39.0",
    "openai": "^4.73.0"
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
